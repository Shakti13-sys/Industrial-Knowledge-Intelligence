# --- LLM provider (Groq, OpenAI-compatible) ---------------------------
# NOTE: the original .env.example used GROK_API_KEY while the code read
# GROQ_API_KEY -- the app never actually picked up the key. Fixed here.
GROQ_API_KEY=your_groq_api_key_here
LLM_MODEL=llama-3.3-70b-versatile
LLM_BASE_URL=https://api.groq.com/openai/v1

# --- App ---------------------------------------------------------------
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:3000

# --- Auth (demo single-account login; see security.py) -----------------
JWT_SECRET=please-change-this-to-a-long-random-string
DEMO_USERNAME=demo
DEMO_PASSWORD=ikip-demo

# --- Storage -------------------------------------------------------------
UPLOAD_DIR=uploads
ENTITIES_FILE=data/entities.json
DOCUMENTS_FILE=data/documents.json
MAX_UPLOAD_MB=15
